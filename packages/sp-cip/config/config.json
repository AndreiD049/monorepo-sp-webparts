{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "cip-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/cip/CipWebPart.js",
          "manifest": "./src/webparts/cip/CipWebPart.manifest.json"
        }
      ]
    }
  },
  "externals": {
    "luxon": {
      "path": "https://cdnjs.cloudflare.com/ajax/libs/luxon/2.3.1/luxon.min.js",        
      "globalName": "luxon"
    }
  },
  "localizedResources": {
    "CipWebPartStrings": "lib/webparts/cip/loc/{locale}.js",
	"PropertyControlStrings": "node_modules/@pnp/spfx-property-controls/lib/loc/{locale}.js"
  }
}
