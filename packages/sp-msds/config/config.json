{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "msds-form-form-customizer": {
      "components": [
        {
          "entrypoint": "./lib/extensions/msdsForm/MsdsFormFormCustomizer.js",
          "manifest": "./src/extensions/msdsForm/MsdsFormFormCustomizer.manifest.json"
        }
      ]
    }
  },
  "externals": {
	"dompurify": {
		"path": "https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.8/purify.min.js",
		"globalName": "DOMPurify"
	}
  },
  "localizedResources": {
    "MsdsFormFormCustomizerStrings": "lib/extensions/msdsForm/loc/{locale}.js"
  }
}
